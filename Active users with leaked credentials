ExposureGraphNodes
| where NodeLabel == "user"
| extend props = parse_json(NodeProperties)
| where props.rawData.isActive == true
| where props.rawData.hasLeakedCredentials == true
| where NodeId in (ExposureGraphEdges | project TargetNodeId)
| project
    NodeId,
    AccountName = tostring(props.rawData.accountName),
    DisplayName = tostring(props.rawData.accountDisplayName),
    UPN = tostring(props.rawData.accountUpn),
    Email = tostring(props.rawData.emailAddress),
    Department = tostring(props.rawData.department)
| distinct NodeId, AccountName, DisplayName, UPN, Email, Department
